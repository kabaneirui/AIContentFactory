DATABASE_URL=postgresql+asyncpg://aimemory:aimemory@localhost:5432/aimemory
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
APP_NAME="AI Memory"

# Content DNA / LLM（OpenAI 兼容 API，未配置时使用规则打标）
# --- DeepSeek 示例（推荐）---
OPENAI_API_KEY=sk-你的DeepSeek密钥
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# --- OpenAI 示例 ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

DNA_TAGGING_ENABLED=true
DNA_TAG_USE_CELERY=false

# Phase 3: platform data adapters
DEFAULT_DATA_ADAPTER=manual
WECHAT_CHANNELS_ENABLED=false
WECHAT_CHANNELS_APP_ID=
WECHAT_CHANNELS_APP_SECRET=
WECHAT_CHANNELS_ACCESS_TOKEN=
WECHAT_CHANNELS_TIMEOUT_SECONDS=30

# B站：播放/点赞/评论/分享/收藏走公开接口，默认开启，无需 AppKey/Secret，
# 只需在视频「平台视频ID」填 BV 号即可在详情页点「同步数据」。
# APP_KEY/SECRET/ACCESS_TOKEN 仅用于未来的创作者中心稿件列表等授权接口。
BILIBILI_ENABLED=true
BILIBILI_APP_KEY=
BILIBILI_APP_SECRET=
BILIBILI_ACCESS_TOKEN=
BILIBILI_TIMEOUT_SECONDS=30
